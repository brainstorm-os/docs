---
// Replaces Starlight's language dropdown with the marketing site's EN/DE pill
// switcher, so the language control matches getbrainstorm.online exactly
// (same as ThemeSelect mirrors the marketing sun/moon toggle).
//
// Locale scheme mirrors the marketing site: English at the root, German under
// /de/. Each option links to the equivalent page in that locale, so switching
// keeps you where you are.
const here = Astro.url.pathname;
const neutral = here.replace(/^\/de(?=\/|$)/, "") || "/";
const deHref = neutral === "/" ? "/de/" : `/de${neutral}`;
const onDe = here === "/de" || here.startsWith("/de/");

const opts = [
	{ code: "en", label: "EN", name: "English", href: neutral, current: !onDe },
	{ code: "de", label: "DE", name: "Deutsch", href: deHref, current: onDe },
] as const;
---

<nav class="bs-lang" aria-label="Language">
	{
		opts.map((o) => (
			<a
				class="bs-lang__opt"
				href={o.href}
				hreflang={o.code}
				lang={o.code}
				aria-current={o.current ? "true" : undefined}
				aria-label={o.name}
			>
				{o.label}
			</a>
		))
	}
</nav>

<style>
	.bs-lang {
		display: inline-flex;
		align-items: center;
		gap: 2px;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: var(--sl-text-xs);
		letter-spacing: -0.01em;
	}
	.bs-lang__opt {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 26px;
		padding: 5px 6px;
		border-radius: 0.25rem;
		color: var(--sl-color-gray-3);
		text-decoration: none;
		transition:
			color 0.2s ease,
			background 0.2s ease;
	}
	.bs-lang__opt:hover {
		color: var(--sl-color-white);
		background: var(--sl-color-gray-6);
	}
	.bs-lang__opt[aria-current="true"] {
		color: var(--sl-color-white);
		font-weight: 600;
	}
</style>
