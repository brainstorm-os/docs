---
// Replaces Starlight's language dropdown with the marketing site's pill
// switcher, so the language control matches getbrainstorm.online exactly
// (same as ThemeSelect mirrors the marketing sun/moon toggle).
//
// Locale scheme mirrors the marketing site: English at the root, the rest under
// a `/<code>/` prefix. Each option links to the equivalent page in that locale,
// so switching keeps you where you are. Add a locale here + in astro.config's
// `locales` and it flows through.
const prefixed = [
	{ code: "de", label: "DE", name: "Deutsch" },
	{ code: "fr", label: "FR", name: "Français" },
] as const;

const here = Astro.url.pathname;
const prefixRe = new RegExp(`^/(?:${prefixed.map((l) => l.code).join("|")})(?=/|$)`);
const neutral = here.replace(prefixRe, "") || "/";
const onLocale = (code: string) => here === `/${code}` || here.startsWith(`/${code}/`);
const localize = (code: string) => (neutral === "/" ? `/${code}/` : `/${code}${neutral}`);

const opts = [
	{ code: "en", label: "EN", name: "English", href: neutral, current: !prefixed.some((l) => onLocale(l.code)) },
	...prefixed.map((l) => ({ ...l, href: localize(l.code), current: onLocale(l.code) })),
];
---

<nav class="bs-lang" aria-label="Language">
	{
		opts.map((o) => (
			<a
				class="bs-lang__opt"
				href={o.href}
				hreflang={o.code}
				lang={o.code}
				aria-current={o.current ? "true" : undefined}
				aria-label={o.name}
			>
				{o.label}
			</a>
		))
	}
</nav>

<style>
	.bs-lang {
		display: inline-flex;
		align-items: center;
		gap: 2px;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: var(--sl-text-xs);
		letter-spacing: -0.01em;
	}
	.bs-lang__opt {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 26px;
		padding: 5px 6px;
		border-radius: 0.25rem;
		color: var(--sl-color-gray-3);
		text-decoration: none;
		transition:
			color 0.2s ease,
			background 0.2s ease;
	}
	.bs-lang__opt:hover {
		color: var(--sl-color-white);
		background: var(--sl-color-gray-6);
	}
	.bs-lang__opt[aria-current="true"] {
		color: var(--sl-color-white);
		font-weight: 600;
	}
</style>
